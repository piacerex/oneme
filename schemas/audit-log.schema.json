{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/audit-log.schema.json",
  "title": "oneme Audit Log",
  "type": "object",
  "required": ["id", "teamId", "actorId", "action", "targetType", "targetId", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "teamId": {
      "type": "string",
      "minLength": 1
    },
    "actorId": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": [
        "team.member.invited",
        "team.member.role_changed",
        "app.created",
        "api_key.created",
        "api_key.revoked",
        "asset.reviewed",
        "billing.plan_changed"
      ]
    },
    "targetType": {
      "type": "string",
      "enum": ["team", "member", "app", "api_key", "asset", "billing_plan"]
    },
    "targetId": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
