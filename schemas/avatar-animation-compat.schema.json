{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/avatar-animation-compat.schema.json",
  "title": "oneme Avatar Animation Compatibility",
  "type": "object",
  "required": ["format", "status", "requiredHumanoidBones", "missingHumanoidBones", "expressions", "notes"],
  "additionalProperties": false,
  "properties": {
    "format": {
      "type": "string",
      "enum": ["vrm"]
    },
    "status": {
      "type": "string",
      "enum": ["contract_ready", "runtime_ready", "blocked"]
    },
    "requiredHumanoidBones": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "missingHumanoidBones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expressions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
