{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/usage-event.schema.json",
  "title": "oneme Usage Event",
  "type": "object",
  "required": ["id", "teamId", "appId", "metric", "quantity", "occurredAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "teamId": {
      "type": "string",
      "minLength": 1
    },
    "appId": {
      "type": "string",
      "minLength": 1
    },
    "apiKeyId": {
      "type": "string",
      "minLength": 1
    },
    "metric": {
      "type": "string",
      "enum": [
        "avatar_created",
        "model_exported",
        "model_downloaded",
        "api_request",
        "storage_byte_hour"
      ]
    },
    "quantity": {
      "type": "integer",
      "minimum": 1
    },
    "metadata": {
      "type": "object"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
