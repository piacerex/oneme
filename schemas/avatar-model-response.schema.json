{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/avatar-model-response.schema.json",
  "title": "oneme Avatar Model Response",
  "type": "object",
  "required": ["avatarId", "format", "modelUrl", "exportJobId"],
  "additionalProperties": false,
  "properties": {
    "avatarId": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": ["glb"]
    },
    "modelUrl": {
      "type": "string",
      "minLength": 1
    },
    "exportJobId": {
      "type": "string",
      "minLength": 1
    },
    "cacheHit": {
      "type": "boolean"
    }
  }
}
