{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/ai-generation-job.schema.json",
  "title": "oneme AI Generation Job",
  "type": "object",
  "required": ["id", "status", "input", "candidates", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "succeeded", "failed", "rejected"]
    },
    "input": {
      "type": "object",
      "required": ["avatarConfig", "safeHints"],
      "additionalProperties": false,
      "properties": {
        "avatarConfig": {
          "type": "object"
        },
        "safeHints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "skinColor": { "type": "string" },
            "hairColor": { "type": "string" },
            "facePreset": { "type": "string" },
            "hairPreset": { "type": "string" }
          }
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "error": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "finishedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "required": ["id", "stylePreset", "cacheKey", "configPatch", "textureCandidate", "safety"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "stylePreset": {
          "type": "string",
          "enum": ["clean", "expressive", "event"]
        },
        "cacheKey": {
          "type": "string",
          "minLength": 1
        },
        "configPatch": {
          "type": "object"
        },
        "textureCandidate": {
          "type": "object",
          "required": ["palette", "notes"],
          "additionalProperties": false,
          "properties": {
            "palette": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "safety": {
          "type": "object",
          "required": ["status", "reasons"],
          "additionalProperties": false,
          "properties": {
            "status": {
              "type": "string",
              "enum": ["approved", "rejected"]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
