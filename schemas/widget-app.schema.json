{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/widget-app.schema.json",
  "title": "oneme Widget App",
  "type": "object",
  "required": ["id", "name", "apiKeys", "allowedOrigins", "theme", "allowedParts"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "apiKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedOrigins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "theme": {
      "type": "string",
      "enum": ["light", "mint", "mono"]
    },
    "allowedParts": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
