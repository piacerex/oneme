{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/asset-review.schema.json",
  "title": "oneme Asset Review",
  "type": "object",
  "required": ["id", "assetId", "teamId", "status", "licenseStatus", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "assetId": {
      "type": "string",
      "minLength": 1
    },
    "teamId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "submitted", "approved", "rejected", "archived"]
    },
    "licenseStatus": {
      "type": "string",
      "enum": ["unknown", "verified", "needs_review", "blocked"]
    },
    "reviewerId": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["approve", "reject", "request_changes"]
    },
    "notes": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
