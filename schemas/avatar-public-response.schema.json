{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/avatar-public-response.schema.json",
  "title": "oneme Avatar Public Response",
  "type": "object",
  "required": ["avatarId", "publicUrl", "embedUrl", "configUrl", "visibility", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "avatarId": {
      "type": "string",
      "minLength": 1
    },
    "publicUrl": {
      "type": "string",
      "minLength": 1
    },
    "embedUrl": {
      "type": "string",
      "minLength": 1
    },
    "configUrl": {
      "type": "string",
      "minLength": 1
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "unlisted", "private"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
