{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/incident.schema.json",
  "title": "oneme Incident",
  "type": "object",
  "required": ["id", "severity", "status", "summary", "detectedAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["minor", "major", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["investigating", "mitigating", "resolved", "postmortem"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "affectedTeams": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affectedApps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recoveryActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "retry_export_jobs",
          "pause_webhook_endpoint",
          "revoke_api_key",
          "rollback_asset",
          "publish_status_update"
        ]
      }
    },
    "customerImpact": {
      "type": "string"
    },
    "detectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "resolvedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
