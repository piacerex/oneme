{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneme.local/schemas/asset-validation.schema.json",
  "title": "oneme Asset Validation",
  "type": "object",
  "required": ["id", "assetId", "teamId", "status", "checks", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "assetId": {
      "type": "string",
      "minLength": 1
    },
    "teamId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": ["file_present", "format_supported", "license_recorded", "geometry_readable"]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed"]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
